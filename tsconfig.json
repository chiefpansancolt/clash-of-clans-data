{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "types": ["node", "jest"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/types": ["src/types/index.ts"],
      "@/types/*": ["src/types/*"],
      "@/common/*": ["src/common/*"],
      "@/modules/*": ["src/modules/*"],
      "@/calculators": ["src/modules/calculators/index.ts"],
      "@/calculators/*": ["src/modules/calculators/*"],
      "@/magic-items": ["src/modules/magic-items/index.ts"],
      "@/magic-items/*": ["src/modules/magic-items/*"],
      "@/season-pass": ["src/modules/season-pass/index.ts"],
      "@/season-pass/*": ["src/modules/season-pass/*"],
      "@/data/*": ["data/*"],
      "@/images/*": ["images/*"]
    }
  },
  "include": ["src", "sample", "tests"],
  "exclude": ["node_modules", "dist"]
}
